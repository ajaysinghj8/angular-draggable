  "description": "Angular directive to make HTML elements draggable.",
  "main": "dist/fesm2022/angular-draggable.mjs",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "esm2022": "./dist/esm2022/angular-draggable.mjs",
      "default": "./dist/fesm2022/angular-draggable.mjs"
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublish": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CoderAjay/angular-draggable.git"
  },
  "keywords": [
